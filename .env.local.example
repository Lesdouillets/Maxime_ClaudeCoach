# Strava OAuth
# Récupère ton Client ID depuis https://www.strava.com/settings/api
NEXT_PUBLIC_STRAVA_CLIENT_ID=your_client_id_here

# Redirect URI — doit correspondre exactement à ce qui est configuré dans ton app Strava
# Pour GitHub Pages: https://{username}.github.io/claude-coach/strava/callback
# Pour dev local: http://localhost:3000/strava/callback
NEXT_PUBLIC_STRAVA_REDIRECT_URI=http://localhost:3000/strava/callback

# ⚠️  ATTENTION: client_secret exposé côté client = risque de sécurité
# Acceptable pour usage PERSONNEL uniquement (app privée).
# Pour un déploiement public, utilise un proxy backend pour l'échange de token.
NEXT_PUBLIC_STRAVA_CLIENT_SECRET=your_client_secret_here

# Base path pour GitHub Pages (ex: /claude-coach)
# Laisser vide pour dev local
NEXT_PUBLIC_BASE_PATH=
